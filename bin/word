#!/usr/bin/env python3

import sys
import shlex
import contextlib

if len(sys.argv) < 1 or sys.argv[1] == "--help":
    print("word: select Nth word per line of stdin", file=sys.stderr)
    print("Usage: word <N>", file=sys.stderr)
    sys.exit(0)

word = int(sys.argv[1])

with contextlib.suppress(EOFError):
    while (line := input()):
        print(shlex.split(line)[word], flush=True)
