#!/usr/bin/env zsh
set -euo pipefail

declare MAN_PAGE

# If `man(1)` executes us as a pager, then `MAN_PN` will be set, and
# the man page contents will come from stdin.
# We don't actually care about the stdin; we'll use Vim's `Man` command instead.
# But if we're executed as a command by the user, and not as a pager,
# then the man page will be passed as an argument.
if [[ -n "${MAN_PN:-}" ]]; then
	# …It's also backslash escaped, apparently...
	MAN_PAGE="${MAN_PN//\\/}"
else
	MAN_PAGE="$1"
fi

# Also, limit the width to no more than 160.
MAX_COLS="${MAX_COLS:-160}"
declare COLS
COLS="$({
	# Doing this in a subshell, so we can handle e.g. `tput` not existing gracefully.
	if ! tput cols; then
		return
	fi
})"


if [[ -n "${COLS:-}" ]]; then
	# Safely try to parse COLS as an integer.
	# Unlike arithmetic expansion, `printf -v` will fail
	# if $COLS is not integer-y.
	declare -i PARSED_COLS
	if printf -v PARSED_COLS "%d" "$COLS" 2>/dev/null; then
		if [[ "$PARSED_COLS" -gt "$MAX_COLS" ]]; then
			export MANWIDTH="$MAX_COLS"
		else
			export MANWIDTH="$COLS"
		fi
	fi
fi

exec nvim "man://$MAN_PAGE"
