#!/usr/bin/env python3

import shutil
import shlex
import os
from pathlib import Path
import sys
import subprocess

NIXOS_OPT_LLVM = Path('/run/current-system/sw/opt/llvm/bin/cc')

CC = None
if cc_from_env := os.getenv("CC"):
    CC = shutil.which(cc_from_env)

if not CC:
    if NIXOS_OPT_LLVM.exists(follow_symlinks=True):
        CC = NIXOS_OPT_LLVM.as_posix()

if not CC:
    raise ValueError("cannot find C compiler; set $CC to override")

cc_bin = Path(CC).parent
path = os.environ['PATH'].split(os.pathsep)
path.insert(0, cc_bin.as_posix())
os.environ['PATH'] = os.pathsep.join(path)

libraries = sys.argv[1:]
if not libraries:
    raise ValueError("usage: find-lib <FOOLIB>")

args = [
    CC,
    "-Wl,-t",
    # GNU ld complains if both input and output file are /dev/null
    "-o", "/dev/zero",
    "/dev/null",
    "-shared",
    "-nostdlib",
    *[f'-l{lib}' for lib in libraries],
    *shlex.split(os.getenv("CFLAGS", "")),
]

proc = subprocess.run(
    args,
    executable=CC,
    stdout=subprocess.PIPE,
    encoding='utf-8',
    universal_newlines=True,
    timeout=10.0,
)
if proc.returncode:
    print(proc.stdout, flush=True)
    sys.exit(proc.returncode)

lines = proc.stdout.splitlines()
try:
    # GNU ld includes the input source file as well as libraries.
    lines.remove("/dev/null")
except ValueError:
    pass

print('\n'.join(lines), flush=True)
