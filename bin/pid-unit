#!/usr/bin/env python3

from argparse import ArgumentParser, REMAINDER
from ctypes import cdll, c_char_p, byref, c_uint
import shutil
import subprocess
from pathlib import Path
from typing import cast
import os
import sys

def prepend(var_name: str, elem: str):
    old = os.getenv(var_name, '').split(os.pathsep)
    os.environ[var_name] = os.pathsep.join([elem, *old])

systemctl = shutil.which('systemctl') or os.environ.get('SYSTEMCTL', None)
if not systemctl:
    raise ValueError("'systemctl' binary not found")

systemctl_lib = Path(systemctl).resolve().parent.parent.joinpath('lib').as_posix()

prepend('LIBRARY_PATH', systemctl_lib)
prepend('LD_LIBRARY_PATH', systemctl_lib)

sofile = subprocess.check_output(['find-libs', 'systemd'], encoding='utf-8').strip()
if not sofile:
    raise ValueError('cannot find libsystemd')

libsystemd = cdll.LoadLibrary(sofile)

parser = ArgumentParser("pid-unit")
parser.add_argument("pids", type=int, nargs='+')
args = parser.parse_args()
pids = cast(list[int], args.pids)

for pid in pids:
    uid_dest = c_uint(0)
    if e := libsystemd.sd_pid_get_owner_uid(pid, byref(uid_dest)):
        e: int = abs(e)
        raise OSError(e, os.strerror(e))

    is_user_unit = uid_dest.value == os.getuid()

    getter_fn = libsystemd.sd_pid_get_user_unit if is_user_unit else libsystemd.sd_pid_get_unit
    unit_dest = c_char_p()

    if e := getter_fn(pid, byref(unit_dest)):
        e = abs(e)
        raise OSError(e, os.strerror(e))

    if unit_dest.value is None:
        raise ValueError(f"no unit for pid {pid} found")

    print(unit_dest.value.decode('utf-8'))
